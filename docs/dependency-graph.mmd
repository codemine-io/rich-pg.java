%% rich-pg.java module dependency graph
%% Nodes are Java classes under src/main/java/io/codemine/java/richpg/.
%% Edges point from a module to what it depends on.
flowchart LR
  subgraph session["session"]
    Session["Session<br/><small>owns pool, execute/executeTransaction</small>"]
    SessionSettings["SessionSettings<br/><small>conn/pool/observability config</small>"]
  end

  subgraph transaction["transaction"]
    Transaction["Transaction<br/><small>unit of work, pure & re-runnable</small>"]
    ConnectionExecutionContext["ConnectionExecutionContext<br/><small>plain ExecutionContext over a Connection</small>"]
    ExecutionContext["ExecutionContext<br/><small>execute + savepoints in-tx</small>"]
    TransactionSettings["TransactionSettings<br/><small>isolation level + read-only flag</small>"]
  end

  subgraph support["support"]
    RetryStrategy["RetryStrategy<br/><small>same/new-connection/no-retry decision</small>"]
    ClassifiedSqlFailure["ClassifiedSqlFailure<br/><small>wraps failure + extracted SQLSTATE</small>"]
    IsolationLevel["IsolationLevel<br/><small>PG isolation levels → JDBC</small>"]
    Telemetry["Telemetry<br/><small>logger, OTel traces & metrics</small>"]
  end

  Session --> ClassifiedSqlFailure
  Session --> ConnectionExecutionContext
  Session --> ExecutionContext
  Session --> IsolationLevel
  Session --> SessionSettings
  Session --> RetryStrategy
  Session --> Telemetry
  Session --> Transaction
  Session --> TransactionSettings

  SessionSettings --> Session

  Transaction --> ClassifiedSqlFailure
  Transaction --> ExecutionContext

  ExecutionContext --> Transaction

  TransactionSettings --> IsolationLevel
  TransactionSettings --> Transaction

  IsolationLevel --> Transaction

  RetryStrategy --> ClassifiedSqlFailure

  Telemetry --> Session
  Telemetry --> SessionSettings
  Telemetry --> Transaction
  Telemetry --> TransactionSettings
